<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.example.skite">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/btn_star"
        android:label="@string/app_name"
        android:name="com.example.skite.SkiteApp"
        android:supportsRtl="true"
        android:theme="@style/Theme.Skite">

        <activity
            android:exported="true"
            android:label="@string/app_name"
            android:name="com.example.skite.MainActivity"
            android:configChanges="locale|layoutDirection"
            android:theme="@style/Theme.Skite">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

    </application>
</manifest>